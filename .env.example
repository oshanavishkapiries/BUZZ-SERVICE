# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENV=development
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buzz_service
DB_USER=buzz_user
DB_PASSWORD=secure_password
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=20
DB_MAX_IDLE_CONNECTIONS=5

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Queue Configuration
QUEUE_CONCURRENCY=10
QUEUE_EMAIL_WEIGHT=3
QUEUE_SMS_WEIGHT=3
QUEUE_PUSH_WEIGHT=2
QUEUE_INAPP_WEIGHT=2
QUEUE_BATCH_WEIGHT=1

# Email Provider Configuration
# Options: ses, smtp
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@buzz.local
EMAIL_FROM_NAME=Buzz Service
EMAIL_RATE_LIMIT_RPS=10

# Amazon SES Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# SMTP Configuration (used when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# SMS Provider Configuration
# Options: notifylk, twilio, router (router uses NotifyLK for Sri Lanka +94, Twilio for others)
SMS_PROVIDER=router
SMS_RATE_LIMIT_PER_SECOND=10
SMS_MAX_SEGMENTS=3
SMS_DEFAULT_SENDER_ID=Buzz

# NotifyLK Configuration (Sri Lanka SMS)
NOTIFYLK_USER_ID=your_notifylk_user_id
NOTIFYLK_API_KEY=your_notifylk_api_key
NOTIFYLK_SENDER_ID=YourBrand

# Twilio Configuration (International SMS Fallback)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_MESSAGING_SERVICE_SID=

# Firebase Cloud Messaging (FCM) Configuration
FCM_CREDENTIALS_FILE=firebase-adminsdk.json
FCM_PROJECT_ID=your-firebase-project-id

# Push Notification Settings
PUSH_BATCH_SIZE=500
PUSH_DEFAULT_ICON=https://yourdomain.com/icon.png
PUSH_DEFAULT_BADGE=https://yourdomain.com/badge.png

