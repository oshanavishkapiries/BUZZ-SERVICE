# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
ENV=development
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=buzz_service
DB_USER=buzz_user
DB_PASSWORD=secure_password
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=20
DB_MAX_IDLE_CONNECTIONS=5

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---------------------------------------------------------------------------
# Queue
# ---------------------------------------------------------------------------
QUEUE_CONCURRENCY=10
QUEUE_EMAIL_WEIGHT=3
QUEUE_SMS_WEIGHT=3
QUEUE_PUSH_WEIGHT=2
QUEUE_INAPP_WEIGHT=2
QUEUE_BATCH_WEIGHT=1

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info      # debug | info | warn | error
LOG_FORMAT=json     # json | text

# ---------------------------------------------------------------------------
# Provider credentials are stored in the database, not here.
# Use POST /api/v1/providers or the Providers page in the client app to
# register email (ses, smtp), SMS (twilio, textlk), and push (fcm) configs.
# ---------------------------------------------------------------------------
